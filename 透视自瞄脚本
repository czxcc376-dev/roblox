-- ==================== ESP 核心修复逻辑 ====================
local function removeESP(player)
    if not espObjects[player] then return end
    
    -- 断开所有事件连接
    if espObjects[player].humanoidConn then
        espObjects[player].humanoidConn:Disconnect()
    end
    if espObjects[player].charConn then
        espObjects[player].charConn:Disconnect()
    end
    
    -- 销毁ESP对象
    pcall(function()
        if espObjects[player].highlight then
            espObjects[player].highlight:Destroy()
        end
        if espObjects[player].billboard then
            espObjects[player].billboard:Destroy()
        end
    end)
    
    espObjects[player] = nil
end

local function createESP(player)
    if player == p or not settings.esp or espObjects[player] then return end
    if not player.Character then return end

    -- 等待角色核心部件加载（兼容R6/R15）
    local char = player.Character
    local humanoid = char:WaitForChild("Humanoid", 5)
    local rootPart = char:WaitForChild("HumanoidRootPart", 5)
    local head = char:WaitForChild("Head", 5)
    
    if not humanoid or not rootPart or not head or humanoid.Health <= 0 then
        task.delay(1, createESP, player) -- 1秒后重试
        return
    end

    -- 初始化ESP对象容器
    espObjects[player] = {}

    -- 1. 创建高亮（强制置顶）
    local highlight = Instance.new("Highlight")
    highlight.Name = "PlayerESP_Highlight"
    highlight.Parent = char
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 0)
    highlight.FillTransparency = 0.75
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- 强制显示在最上层
    highlight.Adornee = char
    espObjects[player].highlight = highlight

    -- 2. 创建信息面板（无黑底+适配显示）
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "PlayerESP_Billboard"
    billboard.Parent = rootPart
    billboard.Size = UDim2.new(0, 80, 0, 35)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0) -- 提高偏移避免被模型遮挡
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = 1000 -- 扩大显示距离
    billboard.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    espObjects[player].billboard = billboard

    -- 面板内容
    local container = Instance.new("Frame", billboard)
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 1

    -- 玩家名
    local nameLabel = Instance.new("TextLabel", container)
    nameLabel.Size = UDim2.new(1, 0, 0.4, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 9
    nameLabel.Text = player.Name
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.TextScaled = false

    -- 距离
    local distLabel = Instance.new("TextLabel", container)
    distLabel.Size = UDim2.new(1, 0, 0.3, 0)
    distLabel.Position = UDim2.new(0, 0, 0.4, 0)
    distLabel.BackgroundTransparency = 1
    distLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
    distLabel.Font = Enum.Font.Gotham
    distLabel.TextSize = 8
    distLabel.Text = "0m"
    distLabel.TextStrokeTransparency = 0
    distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

    -- 血量
    local healthLabel = Instance.new("TextLabel", container)
    healthLabel.Size = UDim2.new(1, 0, 0.3, 0)
    healthLabel.Position = UDim2.new(0, 0, 0.7, 0)
    healthLabel.BackgroundTransparency = 1
    healthLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    healthLabel.Font = Enum.Font.Gotham
    healthLabel.TextSize = 8
    healthLabel.Text = string.format("%d HP", humanoid.Health)
    healthLabel.TextStrokeTransparency = 0
    healthLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

    -- 3. 监听人类oid死亡事件
    local humanoidConn = humanoid.Died:Connect(function()
        removeESP(player)
    end)
    espObjects[player].humanoidConn = humanoidConn

    -- 4. 监听角色重生事件
    local charConn = player.CharacterAdded:Connect(function(newChar)
        removeESP(player)
        task.wait(1) -- 等待新角色加载
        if settings.esp then
            createESP(player)
        end
    end)
    espObjects[player].charConn = charConn

    -- 5. 定时更新ESP信息（避免单次更新失效）
    task.spawn(function()
        while settings.esp and espObjects[player] and player.Character do
            pcall(function()
                local myRoot = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                if not myRoot then return end

                -- 更新距离
                local distance = math.floor((rootPart.Position - myRoot.Position).Magnitude)
                distLabel.Text = string.format("%dm", distance)

                -- 更新血量和颜色
                local health = math.floor(humanoid.Health)
                healthLabel.Text = string.format("%d HP", health)
                if health > 70 then
                    healthLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                elseif health > 30 then
                    healthLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
                else
                    healthLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
                end

                -- 更新高亮颜色（按距离）
                if distance < 50 then
                    highlight.FillColor = Color3.fromRGB(255, 0, 0)
                elseif distance < 150 then
                    highlight.FillColor = Color3.fromRGB(255, 150, 0)
                else
                    highlight.FillColor = Color3.fromRGB(255, 255, 0)
                end
            end)
            task.wait(0.1) -- 高频更新确保信息同步
        end
    end)
end

-- 全局ESP刷新：每秒检查所有玩家ESP状态，缺失则重建
local function startESPRefresh()
    if espRefreshConn then
        espRefreshConn:Disconnect()
    end

    espRefreshConn = RunService.Heartbeat:Connect(function()
        if not settings.esp then return end

        for _, player in pairs(Players:GetPlayers()) do
            if player ~= p and player.Character and not espObjects[player] then
                createESP(player)
            end
        end
    end)
end

local function toggleESP(state)
    settings.esp = state

    -- 关闭ESP：清理所有对象+断开刷新
    if not state then
        if espRefreshConn then
            espRefreshConn:Disconnect()
            espRefreshConn = nil
        end
        for player, _ in pairs(espObjects) do
            removeESP(player)
        end
        return
    end

    -- 开启ESP：创建所有玩家ESP+启动全局刷新
    startESPRefresh()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= p then
            task.spawn(createESP, player)
        end
    end
end

-- ==================== 自动瞄准（不变）====================
local function getAimTargetPart(char)
    if settings.aimPart == "头部" then
        return char:FindFirstChild("Head")
    elseif settings.aimPart == "脖子" then
        local upperTorso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
        if upperTorso then
            return upperTorso, Vector3.new(0, 0.5, 0)
        end
        return char:FindFirstChild("Head")
    elseif settings.aimPart == "胸部" then
        return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    end
    return char:FindFirstChild("Head")
end

local function getClosestEnemy()
    local closestPlayer = nil
    local closestDist = math.huge
    local myChar = p.Character
    
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local myRoot = myChar.HumanoidRootPart
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= p then
            local char = player.Character
            if not char then continue end

            local aimPart, offset = getAimTargetPart(char)
            local humanoid = char:FindFirstChild("Humanoid")
            
            if not aimPart or not humanoid or humanoid.Health <= 0 then
                continue
            end

            local targetPos = aimPart.Position
            if offset then
                targetPos = targetPos + offset
            end

            local distance = (targetPos - myRoot.Position).Magnitude
            if distance > 300 then
                continue
            end

            local screenPos, onScreen = camera:WorldToViewportPoint(targetPos)
            if not onScreen then
                continue
            end

            local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
            if screenDist > settings.fovSize then
                continue
            end

            -- 掩体判断
            local rayOrigin = camera.CFrame.Position
            local rayDirection = (targetPos - rayOrigin).Unit * 300
            local raycastParams = RaycastParams.new()
            raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
            raycastParams.FilterDescendantsInstances = {p.Character, camera}
            raycastParams.IgnoreWater = true
            
            local raycastResult = workspace:Raycast(rayOrigin, rayDirection, raycastParams)
            if raycastResult and raycastResult.Instance:IsDescendantOf(char) then
                if screenDist < closestDist then
                    closestDist = screenDist
                    closestPlayer = {player = player, targetPos = targetPos}
                end
            end
        end
    end
    
    return closestPlayer
end

local function toggleAutoAim(state)
    settings.autoAim = state
    
    if aimConnection then
        aimConnection:Disconnect()
        aimConnection = nil
    end
    
    if not state then
        if fovCircle then
            local centerDot = fovCircle:FindFirstChild("Frame")
            if centerDot then
                centerDot.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                centerDot.Size = UDim2.new(0, 4, 0, 4)
            end
        end
        return
    end
    
    aimConnection = RunService.RenderStepped:Connect(function()
        local targetData = getClosestEnemy()
        
        if targetData then
            local targetPos = targetData.targetPos
            local camCFrame = camera.CFrame
            local direction = (targetPos - camCFrame.Position).Unit
            local newCFrame = CFrame.new(camCFrame.Position, camCFrame.Position + direction)
            
            local lerpAmount = settings.aimSpeed / 100
            camera.CFrame = camCFrame:Lerp(newCFrame, lerpAmount)
            
            if fovCircle then
                local centerDot = fovCircle:FindFirstChild("Frame")
                if centerDot then
                    centerDot.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                    centerDot.Size = UDim2.new(0, 8, 0, 8)
                end
            end
        else
            if fovCircle then
                local centerDot = fovCircle:FindFirstChild("Frame")
                if centerDot then
                    centerDot.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                    centerDot.Size = UDim2.new(0, 4, 0, 4)
                end
            end
        end
    end)
end

-- 切换瞄准部位
local function cycleAimPart()
    local parts = {"头部", "脖子", "胸部"}
    local currentIndex = table.find(parts, settings.aimPart) or 1
    local nextIndex = currentIndex % #parts + 1
    settings.aimPart = parts[nextIndex]
    return settings.aimPart
end

